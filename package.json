{
  "name": "@sla/auditor",
  "version": "2.0.0",
  "description": "Shadow-Logic Auditor — AI-driven technical debt prevention with real-time architectural guardrails",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "sla": "./dist/cli/index.js",
    "sla-init": "./dist/cli/init.js",
    "sla-audit": "./dist/cli/audit.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli/index.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepare": "npm run build"
  },
  "keywords": [
    "ai",
    "code-quality",
    "architectural-guardrails",
    "technical-debt",
    "llm",
    "static-analysis",
    "security",
    "devtools"
  ],
  "author": "SLA-Labs",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "openai": "^4.52.0",
    "@google/generative-ai": "^0.15.0",
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0",
    "chalk": "^5.3.0",
    "glob": "^11.0.0",
    "zod": "^3.23.8",
    "micromatch": "^4.0.8",
    "ora": "^8.1.0",
    "enquirer": "^2.4.1",
    "boxen": "^8.0.1",
    "table": "^6.8.2",
    "diff": "^7.0.0",
    "fast-glob": "^3.3.2",
    "ignore": "^5.3.2",
    "semver": "^7.6.3",
    "node-cache": "^5.1.2",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "dotenv": "^16.4.5",
    "strip-ansi": "^7.1.0"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "@types/node": "^22.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/micromatch": "^4.0.9",
    "@types/diff": "^5.2.3",
    "@types/semver": "^7.5.8",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.4",
    "@types/jest": "^29.5.12",
    "eslint": "^9.8.0",
    "@typescript-eslint/eslint-plugin": "^8.1.0",
    "@typescript-eslint/parser": "^8.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist/",
    ".sla/",
    "README.md"
  ]
